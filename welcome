    <textarea id="q-other-tools" placeholder="Example: Google Calendar for scheduling, Mailchimp for email marketing"></textarea>

    <div class="btn-row">
      <button class="btn-back" onclick="prevStep()">Back</button>
      <button class="btn-next" onclick="nextStep()">Continue</button>
    </div>
  </div>

  <!-- STEP 3: Communication -->
  <div class="step" id="step-2">
    <h2>Communication</h2>
    <p class="desc">How do your customers reach you?</p>

    <label>Business phone number (the one customers text/call)</label>
    <input type="tel" id="q-biz-phone" placeholder="(555) 987-6543">

    <label>What phone system is that on?</label>
    <select id="q-phone-system">
      <option value="">Select your phone system</option>
      <option value="openphone">OpenPhone</option>
      <option value="ringcentral">RingCentral</option>
      <option value="google-voice">Google Voice</option>
      <option value="grasshopper">Grasshopper</option>
      <option value="cell">Regular cell phone</option>
      <option value="landline">Landline</option>
      <option value="other">Other</option>
    </select>

    <label>How do customers primarily reach you?</label>
    <div class="option-grid" id="comm-grid">
      <div class="option-card" data-value="sms" onclick="selectOption(this, 'comm')">
        <div class="icon">💬</div>
        <div class="label">Text / SMS</div>
      </div>
      <div class="option-card" data-value="phone" onclick="selectOption(this, 'comm')">
        <div class="icon">📞</div>
        <div class="label">Phone Calls</div>
      </div>
      <div class="option-card" data-value="email" onclick="selectOption(this, 'comm')">
        <div class="icon">📧</div>
        <div class="label">Email</div>
      </div>
      <div class="option-card" data-value="mix" onclick="selectOption(this, 'comm')">
        <div class="icon">🔀</div>
        <div class="label">Mix of Everything</div>
      </div>
    </div>

    <div class="btn-row">
      <button class="btn-back" onclick="prevStep()">Back</button>
      <button class="btn-next" onclick="nextStep()">Continue</button>
    </div>
  </div>

  <!-- STEP 4: Business Rules -->
  <div class="step" id="step-3">
    <h2>How You Operate</h2>
    <p class="desc">Help us match your AI to the way you already run things.</p>

    <label>Business hours</label>
    <input type="text" id="q-hours" placeholder="8am - 6pm, Monday through Saturday">

    <label>Your timezone</label>
    <select id="q-timezone">
      <option value="America/Chicago">Central Time</option>
      <option value="America/New_York">Eastern Time</option>
      <option value="America/Denver">Mountain Time</option>
      <option value="America/Los_Angeles">Pacific Time</option>
      <option value="America/Phoenix">Arizona (no DST)</option>
      <option value="Pacific/Honolulu">Hawaii</option>
      <option value="America/Anchorage">Alaska</option>
    </select>

    <label>How do you handle late payments today? Walk us through your current process.</label>
    <textarea id="q-collections" placeholder="Example: I send a reminder on the 5th, then a late fee on the 10th, then a warning letter on the 20th..."></textarea>

    <label>How often do you want reports?</label>
    <select id="q-reports">
      <option value="weekly">Weekly</option>
      <option value="daily">Daily</option>
      <option value="monthly">Monthly</option>
    </select>

    <label>Is there anything you want your AI to always check with you first before doing?</label>
    <textarea id="q-approvals" placeholder="Example: Always check with me before sending a late fee notice over $500. Always ask me before processing a move-out."></textarea>

    <div class="btn-row">
      <button class="btn-back" onclick="prevStep()">Back</button>
      <button class="btn-next" onclick="nextStep()">Continue</button>
    </div>
  </div>

  <!-- STEP 5: Personality & Review -->
  <div class="step" id="step-4">
    <h2>Final Details</h2>
    <p class="desc">Almost done. Just a couple more things.</p>

    <label>What would you like your AI assistant to call itself?</label>
    <input type="text" id="q-agent-name" placeholder="Examples: Max, Alex, Sam, or just Assistant">

    <label>What personality should it have with your customers?</label>
    <select id="q-personality">
      <option value="friendly-professional">Friendly and professional</option>
      <option value="casual">Casual and laid-back</option>
      <option value="formal">Formal and buttoned-up</option>
      <option value="brief">Brief and to-the-point</option>
    </select>

    <label>Anything else we should know? Special instructions, quirks about your business, things to avoid?</label>
    <textarea id="q-notes" placeholder="Tell us anything that would help your AI do a better job."></textarea>

    <div class="note">
      <strong>One more thing:</strong> Your AI gets smarter the more you work together. The first couple of weeks it might need some guidance on how you like things done. Correct it when it gets something wrong and it will remember for next time. Think of it like training a new employee who happens to learn really fast.
    </div>

    <h2 style="margin-top:40px;">Review Your Info</h2>
    <div class="summary-card" id="summary-card"></div>

    <button class="btn-submit" onclick="submitOnboarding()">Submit and Get Started</button>
    <p id="submit-status" style="text-align:center; margin-top:16px; font-size:0.9rem; display:none;"></p>
  </div>

  <!-- COMPLETION -->
  <div class="completion" id="completion">
    <div class="big-check">🎉</div>
    <h2>You're all set!</h2>
    <p>We have everything we need. Heston will personally set up your AI assistant and reach out within 24 hours with your Telegram bot link. Once connected, your AI starts working immediately.</p>
    <p style="margin-top:24px; color:#1A1A1A; font-weight:600;">Questions? Text Heston directly at (817) 765-4984.</p>
  </div>

</div>

<script>
let currentStep = 0;
const totalSteps = 5;
const selections = { industry: null, comm: null };

function selectOption(el, group) {
  const grid = el.parentElement;
  grid.querySelectorAll('.option-card').forEach(c => c.classList.remove('selected'));
  el.classList.add('selected');
  selections[group] = el.dataset.value;
}

function updateDots() {
  for (let i = 0; i < totalSteps; i++) {
    const dot = document.getElementById('dot-' + i);
    dot.classList.remove('active', 'done');
    if (i === currentStep) dot.classList.add('active');
    else if (i < currentStep) dot.classList.add('done');
  }
}

function nextStep() {
  if (currentStep === 0) {
    const name = document.getElementById('q-name').value.trim();
    const biz = document.getElementById('q-business').value.trim();
    const email = document.getElementById('q-email').value.trim();
    if (!name || !biz || !email || !selections.industry) {
      alert('Please fill in all fields and select your industry.');
      return;
    }
  }

  document.getElementById('step-' + currentStep).classList.remove('active');
  currentStep++;
  document.getElementById('step-' + currentStep).classList.add('active');
  updateDots();
  window.scrollTo({ top: 0, behavior: 'smooth' });

  if (currentStep === 4) buildSummary();
}

function prevStep() {
  document.getElementById('step-' + currentStep).classList.remove('active');
  currentStep--;
  document.getElementById('step-' + currentStep).classList.add('active');
  updateDots();
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function buildSummary() {
  const card = document.getElementById('summary-card');
  const rows = [
    ['Name', document.getElementById('q-name').value],
    ['Business', document.getElementById('q-business').value],
    ['Email', document.getElementById('q-email').value],
    ['Phone', document.getElementById('q-phone').value],
    ['Industry', selections.industry],
    ['Locations', document.getElementById('q-locations').value],
    ['Software', document.getElementById('q-software').value || 'Not specified'],
    ['Phone System', document.getElementById('q-phone-system').value || 'Not specified'],
    ['Customer Channel', selections.comm || 'Not specified'],
    ['Business Hours', document.getElementById('q-hours').value || 'Not specified'],
    ['Timezone', document.getElementById('q-timezone').value],
    ['Report Frequency', document.getElementById('q-reports').value],
    ['AI Name', document.getElementById('q-agent-name').value || 'Not chosen yet'],
    ['Personality', document.getElementById('q-personality').value],
  ];
  card.innerHTML = rows.map(r =>
    '<div class="summary-row"><span class="summary-label">' + r[0] + '</span><span class="summary-value">' + r[1] + '</span></div>'
  ).join('');
}

function submitOnboarding() {
  const status = document.getElementById('submit-status');
  status.style.display = 'block';
  status.textContent = 'Submitting...';
  status.style.color = '#8A8275';

  const data = {
    name: document.getElementById('q-name').value.trim(),
    business: document.getElementById('q-business').value.trim(),
    email: document.getElementById('q-email').value.trim(),
    phone: document.getElementById('q-phone').value.trim(),
    industry: selections.industry,
    locations: document.getElementById('q-locations').value,
    software: document.getElementById('q-software').value,
    software_url: document.getElementById('q-software-url').value.trim(),
    api_access: document.getElementById('q-api-access').value,
    other_tools: document.getElementById('q-other-tools').value.trim(),
    biz_phone: document.getElementById('q-biz-phone').value.trim(),
    phone_system: document.getElementById('q-phone-system').value,
    comm_channel: selections.comm,
    hours: document.getElementById('q-hours').value.trim(),
    timezone: document.getElementById('q-timezone').value,
    collections: document.getElementById('q-collections').value.trim(),
    reports: document.getElementById('q-reports').value,
    approvals: document.getElementById('q-approvals').value.trim(),
    agent_name: document.getElementById('q-agent-name').value.trim(),
    personality: document.getElementById('q-personality').value,
    notes: document.getElementById('q-notes').value.trim()
  };

  const botToken = '8551159625:AAGu3xc5whRDti7viGFsz-h0dSA_C2Ryq_4';
  const chatId = '6516159743';

  const message = '🎉 NEW CLIENT ONBOARDING COMPLETE\n\n' +
    '👤 ' + data.name + '\n' +
    '🏢 ' + data.business + '\n' +
    '📧 ' + data.email + '\n' +
    '📱 ' + data.phone + '\n' +
    '🏭 Industry: ' + data.industry + '\n' +
    '📍 Locations: ' + data.locations + '\n\n' +
    '💻 Software: ' + (data.software || 'Not specified') + '\n' +
    '🔗 URL: ' + (data.software_url || 'N/A') + '\n' +
    '🔌 API: ' + data.api_access + '\n' +
    '🛠 Other tools: ' + (data.other_tools || 'None') + '\n\n' +
    '📞 Biz phone: ' + (data.biz_phone || 'N/A') + '\n' +
    '📡 Phone system: ' + (data.phone_system || 'N/A') + '\n' +
    '💬 Primary channel: ' + (data.comm_channel || 'N/A') + '\n\n' +
    '🕐 Hours: ' + (data.hours || 'N/A') + '\n' +
    '🌎 Timezone: ' + data.timezone + '\n' +
    '📊 Reports: ' + data.reports + '\n' +
    '💰 Collections: ' + (data.collections || 'Not described') + '\n' +
    '⚠️ Needs approval for: ' + (data.approvals || 'Nothing specified') + '\n\n' +
    '🤖 Agent name: ' + (data.agent_name || 'Not chosen') + '\n' +
    '🎭 Personality: ' + data.personality + '\n' +
    '📝 Notes: ' + (data.notes || 'None') + '\n\n' +
    '— Ready to deploy. Create TG bot, configure, and send client their link.';

  navigator.sendBeacon(
    'https://api.telegram.org/bot' + botToken + '/sendMessage',
    new Blob([JSON.stringify({ chat_id: chatId, text: message })], { type: 'application/json' })
  );

  // Show completion
  document.querySelector('.step-indicator').style.display = 'none';
  document.getElementById('step-4').style.display = 'none';
  document.querySelector('h1').style.display = 'none';
  document.querySelector('.subtitle').style.display = 'none';
  document.getElementById('completion').style.display = 'block';
  window.scrollTo({ top: 0, behavior: 'smooth' });
}
</script>

</body>
</html>
